# E2E test environment. Committed (no real secrets) — used only by the Dockerized
# Playwright run (npm run e2e). The DB host is the compose service name `postgres`,
# so this resolves inside the e2e container / CI service network, not on the host.
DATABASE_URL=postgres://fridge:fridge@postgres:5432/fridge_test
NODE_ENV=test
PORT=3001
SESSION_SECRET=test-secret
SEED_ADMIN_NAME=admin
SEED_ADMIN_PASSWORD=e2e-password
PUBLIC_BASE_URL=http://localhost:3001
