# Copy to .env for local development: cp .env.example .env
# .env is gitignored. In production (Render), set these in the dashboard instead.

# Postgres connection string. Matches docker-compose.yml defaults for local dev.
DATABASE_URL=postgres://fridge:fridge@localhost:5432/fridge

# Secret used to sign session cookies. Use a long random value in production.
SESSION_SECRET=dev-only-insecure-secret-change-me

# Absolute base URL, used as the OAuth issuer + in discovery metadata. On Render,
# RENDER_EXTERNAL_URL is used automatically; set this to override (e.g. a tunnel).
PUBLIC_BASE_URL=http://localhost:3000

# Admin user provisioned by db/seed.ts. Read only at seed time; the password is
# hashed before storage and none of these values are committed.
SEED_ADMIN_NAME=admin
SEED_ADMIN_PASSWORD=
