{
  "name": "fridge",
  "version": "0.1.0",
  "description": "Meal planning system with an OAuth-enabled MCP server and web UI",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file-if-exists=.env scripts/seed.ts",
    "db:reset": "tsx --env-file-if-exists=.env scripts/reset.ts && npm run db:push && npm run db:seed"
  },
  "license": "ISC",
  "volta": {
    "node": "26.1.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electric-sql/pglite": "^0.2.17",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
