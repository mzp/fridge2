{
  "name": "fridge",
  "version": "0.1.0",
  "description": "Meal planning system with an OAuth-enabled MCP server and web UI",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/web/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/web/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "license": "ISC",
  "volta": {
    "node": "26.1.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.8.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
